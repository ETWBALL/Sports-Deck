@baseUrl = http://localhost:3000
@contentType = application/json


### ============================================================
###  /api/auth/signup
### ============================================================

### ✅ GOOD — Valid signup with email + password
POST {{baseUrl}}/api/auth/signup
Content-Type: {{contentType}}

{
  "email": "WOORK@example.com",
  "password": "SecurePass123!"
}

###

### ❌ BAD — Duplicate email
POST {{baseUrl}}/api/auth/signup
Content-Type: {{contentType}}

{
  "email": "exidsting@example.com",
  "password": "SecurePass123!"
}

###

### ❌ BAD — Missing password field
POST {{baseUrl}}/api/auth/signup
Content-Type: {{contentType}}

{
  "email": "newuser3@example.com"
}

###

### ❌ BAD — Missing email field
POST {{baseUrl}}/api/auth/signup
Content-Type: {{contentType}}

{
  "password": "SecurePass123!"
}

###

### ❌ BAD — Empty request body
POST {{baseUrl}}/api/auth/signup
Content-Type: {{contentType}}

{}

###

###

### ❌ BAD — Extra unexpected fields (mass assignment attempt)
POST {{baseUrl}}/api/auth/signup
Content-Type: {{contentType}}

{
  "email": "hacker@example.com",
  "password": "SecurePass123!",
  "role": "admin",
  "isVerified": true
}


### ============================================================
###  /api/auth/login
### ============================================================

### ✅ GOOD — Valid login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "WOORK@example.com",
  "password": "SecurePass123!"
}

###

### ❌ BAD — Wrong password
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "newuser@example.com",
  "password": "WrongPassword!"
}

###

### ❌ BAD — Non-existent user
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "ghost@example.com",
  "password": "SecurePass123!"
}

###

### ❌ BAD — Missing email
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "password": "SecurePass123!"
}

###

### ❌ BAD — Missing password
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "newuser@example.com"
}

###

### ❌ BAD — Empty body
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{}

###

### ============================================================
###  /api/auth/refresh
### ============================================================

### ✅ GOOD — Valid refresh token
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refresh_token": "$2b$10$SgETZlInhZGAISBpYLxUxe5sLTDZYIA6zCgkUijITWwoxZZLe6UpK"
}
###

### ❌ BAD — Missing refresh token field
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{}

###

### ❌ BAD — Malformed / tampered refresh token
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6bnVsbCwidXNlcl9pZCI6ImNtbWk2ZnpnYzAwMDBzdXo3bmhubHl4bXkiLCJyb2xlIjoidXNlciIsImlzQmFubmVkIjpmYWxzZSwiaWF0IjoxNzczMDAzNzIxLCJleHAiOjE3NzU1OTU3MjF9.liuiGxMGN603Spps2pDe37_NvlKzy9oJX17tYHJwzSg"
}

###

### ❌ BAD — Expired refresh token
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "PASTE_EXPIRED_REFRESH_TOKEN_HERE"
}

###

### ❌ BAD — Reuse of already-rotated refresh token (replay attack)
# Use a refresh token that has already been consumed in a previous /refresh call
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "PASTE_ALREADY_USED_REFRESH_TOKEN_HERE"
}

###

### ❌ BAD — Random string instead of JWT
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "not-a-real-token-at-all"
}

###

### ❌ BAD — Access token passed instead of refresh token
# Should be rejected — wrong token type
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "PASTE_ACCESS_TOKEN_HERE"
}
